<!DOCTYPE html>
<html lang="et">
<head>
  <meta charset="UTF-8">
  <title>Admin Dashboard</title>
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>

<header class="admin-header">
  <div class="admin-container admin-nav">
    <div class="admin-logo">Groove Admin</div>
    <nav>
      <a href="/">Avaleht</a>
      <a href="/albums">Albumid</a>
      <a href="/admin/logout">Logi välja</a>
    </nav>
  </div>
</header>

<main class="admin-main">
  <div class="admin-container">
    <div class="admin-card">
      <h1 class="admin-title">Albumid</h1>

      <div class="admin-actions">
        <a class="admin-btn primary" href="/admin/albums/new">Lisa uus album</a>
      </div>

      <table class="admin-table">
        <thead>
          <tr>
            <th>ID</th>
            <th>Pealkiri</th>
            <th>Artist</th>
            <th>Žanr</th>
            <th>Aasta</th>
            <th>Hind</th>
            <th>Seisukord</th>
            <th>Tegevused</th>
          </tr>
        </thead>

        <tbody>
          <% albums.forEach(album => { %>
            <tr>
              <td><%= album.id %></td>
              <td><%= album.title %></td>
              <td><%= album.artist %></td>
              <td><%= album.genre %></td>
              <td><%= album.year %></td>
              <td><%= album.price %></td>
              <td><%= album.condition %></td>
              <td>
                <a class="admin-btn" href="/admin/albums/<%= album.id %>/edit">Muuda</a>

                <form method="POST" action="/admin/albums/<%= album.id %>/delete" style="display:inline;">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button class="admin-btn danger" type="submit">Kustuta</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</main>

</body>
</html>