<!DOCTYPE html>
<html lang="et">
<head>
  <meta charset="UTF-8">
  <title>Muuda albumit</title>
</head>
<body>

<h1>Muuda albumit</h1>

<form method="POST" action="/admin/albums/<%= album.id %>/edit">

  <input type="text" name="title" value="<%= album.title %>" required>
  <input type="text" name="artist" value="<%= album.artist %>" required>
  <input type="text" name="genre" value="<%= album.genre %>" required>
  <input type="number" name="year" value="<%= album.year %>" required>
  <input type="number" step="0.01" name="price" value="<%= album.price %>" required>
  <input type="text" name="condition" value="<%= album.condition %>" required>
  <input type="text" name="image" value="<%= album.image %>">

  <button type="submit">
    Salvesta muudatused
  </button>

</form>

</body>
</html>