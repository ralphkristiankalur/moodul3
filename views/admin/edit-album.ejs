<!DOCTYPE html>
<html lang="et">
<head>
  <meta charset="UTF-8">
  <title>Muuda albumit</title>
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>

<header class="admin-header">
  <div class="admin-container admin-nav">
    <div class="admin-logo">Groove Admin</div>
    <nav>
      <a href="/admin/dashboard">Dashboard</a>
      <a href="/admin/logout">Logi välja</a>
    </nav>
  </div>
</header>

<main class="admin-main">
  <div class="admin-container">
    <div class="admin-card">
      <h1 class="admin-title">Muuda albumit</h1>

      <form class="admin-form" method="POST" action="/admin/albums/<%= album.id %>/edit">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

        <input type="text" name="title" value="<%= album.title %>" required>
        <input type="text" name="artist" value="<%= album.artist %>" required>
        <input type="text" name="genre" value="<%= album.genre %>" required>
        <input type="number" name="year" value="<%= album.year %>" required>
        <input type="number" step="0.01" name="price" value="<%= album.price %>" required>
        <input type="text" name="condition" value="<%= album.condition %>" required>
        <input type="text" name="image" value="<%= album.image %>">

        <button class="admin-btn primary" type="submit">Salvesta muudatused</button>
      </form>

      <p>
        <a class="admin-btn" href="/admin/dashboard">Tagasi</a>
      </p>
    </div>
  </div>
</main>

</body>
</html>