<!DOCTYPE html>
<html lang="et">
<head>
  <meta charset="UTF-8">
  <title>Admin Login</title>
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="login-page">

  <div class="login-box">
    <h1>Admin Login</h1>

    <form class="admin-form" method="POST" action="/admin/login">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <input
        type="text"
        name="username"
        placeholder="Kasutajanimi"
        required
      >

      <input
        type="password"
        name="password"
        placeholder="Parool"
        required
      >

      <button class="admin-btn primary" type="submit">
        Logi sisse
      </button>
    </form>
  </div>

</body>
</html>