<!DOCTYPE html>
<html lang="et">
<head>
  <meta charset="UTF-8">
  <title>Admin Login</title>
</head>
<body>

<h1>Admin Login</h1>

<form method="POST" action="/admin/login">
  <input
    type="text"
    name="username"
    placeholder="Kasutajanimi"
    required
  >

  <input
    type="password"
    name="password"
    placeholder="Parool"
    required
  >

  <button type="submit">
    Logi sisse
  </button>
</form>

</body>
</html>