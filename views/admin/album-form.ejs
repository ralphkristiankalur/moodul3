<!DOCTYPE html>
<html lang="et">
<head>
  <meta charset="UTF-8">
  <title>Lisa album</title>
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>

<header class="admin-header">
  <div class="admin-container admin-nav">
    <div class="admin-logo">Groove Admin</div>
    <nav>
      <a href="/admin/dashboard">Dashboard</a>
      <a href="/admin/logout">Logi välja</a>
    </nav>
  </div>
</header>

<main class="admin-main">
  <div class="admin-container">
    <div class="admin-card">
      <h1 class="admin-title">Lisa album</h1>

      <form class="admin-form" method="POST" action="/admin/albums/new">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">

  <input type="text" name="title" placeholder="Pealkiri" required>
  <input type="text" name="artist" placeholder="Artist" required>
  <input type="text" name="genre" placeholder="Žanr" required>
  <input type="number" name="year" placeholder="Aasta" required>
  <input type="number" step="0.01" name="price" placeholder="Hind" required>
  <input type="text" name="condition" placeholder="Seisukord" required>
  <input type="text" name="image" placeholder="Pildi failinimi">

  <button class="admin-btn primary" type="submit">Salvesta album</button>
</form>

      <p>
        <a class="admin-btn" href="/admin/dashboard">Tagasi</a>
      </p>
    </div>
  </div>
</main>

</body>
</html>