<!DOCTYPE html>
<html lang="et">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Groove | Kontakt</title>
  <link rel="stylesheet" href="css/style.css">
</head>
<body>

<header class="header">
  <div class="header-container">

    <a href="/" class="logo">
        <picture>
            <source srcset="assets/webp/bgroove.webp" type="image/webp">
            <img src="assets/webp/bgroove.webp" alt="Cozy Groove vinyl shop interior" width="800" height="520">
        </picture>
    </a>

    <nav>
      <ul class="nav-links">
        <li><a href="/">Avaleht</a></li>
        <li><a href="/albums">Albumid</a></li>
        <li><a href="/varsti">Üritused</a></li>
        <li><a href="/varsti">Meist</a></li>
        <li><a class="active" href="/kontakt">Kontakt</a></li>
      </ul>
    </nav>

    <div class="header-icons">
      <a href="#" aria-label="Search">
        <picture>
          <source srcset="assets/webp/search.webp" type="image/webp">
          <img src="assets/webp/search.webp" alt="Search">
        </picture>
      </a>

      <a href="/ostukorv" aria-label="Cart">
        <picture>
  <source srcset="assets/webp/cart.webp" type="image/webp">
  <img src="assets/webp/cart.webp" alt="Cart">
</picture>
      </a>
    </div>

  </div>
</header>

<main>
  <section class="page-hero contact-hero">
    <div class="container">
      <h1>Kontakt</h1>
      <p>Avaleht / Kontakt</p>
    </div>
  </section>

  <section class="contact-page container">
    <div class="contact-info">
      <h2>Võta meiega ühendust</h2>
      <p>
        Küsimused plaatide, kohviku või ürituste kohta? Kirjuta meile ja vastame esimesel võimalusel.
      </p>

      <div class="contact-card">
        <h3>Asukoht</h3>
        <p>Pärnu mnt. 57, Tallinn</p>
      </div>

      <div class="contact-card">
        <h3>E-post</h3>
        <p>info@groove.ee</p>
      </div>

      <div class="contact-card">
        <h3>Telefon</h3>
        <p>+372 1234 4321</p>
      </div>

      <div class="contact-card">
        <h3>Avatud</h3>
        <p>E-R 10:00 - 20:00</p>
        <p>L-P 11:00 - 18:00</p>
      </div>
    </div>

    <form class="contact-form" action="/kontakt" method="post">

  <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <div class="form-row">
        <label for="name">Nimi</label>
        <input id="name" name="name" type="text" placeholder="Sinu nimi" required>
      </div>

      <div class="form-row">
        <label for="email">E-post</label>
        <input id="email" name="email" type="email" placeholder="sinu@email.ee" required>
      </div>

      <div class="form-row">
        <label for="topic">Teema</label>
        <input id="topic" name="topic" type="text" placeholder="Kirja teema">
      </div>

      <div class="form-row">
        <label for="message">Sõnum</label>
        <textarea id="message" name="message" rows="8" placeholder="Kirjuta oma sõnum..." required></textarea>
      </div>

      <button type="submit">SAADA SÕNUM</button>
      
        <% if (typeof success !== "undefined" && success) { %>
          <p>Sõnum saadeti edukalt!</p>
        <% } %>

    </form>
  </section>

<section class="map-section container">
  <iframe
    class="map-frame"
    src="https://www.google.com/maps?q=P%C3%A4rnu%20mnt%2057%2C%20Tallinn&output=embed"
    width="100%"
    height="310"
    style="border:0;"
    allowfullscreen=""
    loading="lazy"
    referrerpolicy="no-referrer-when-downgrade"
    title="Groove asukoht kaardil">
  </iframe>
</section>
</main>

<footer class="footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <picture>
  <source srcset="assets/webp/dsa.webp" type="image/webp">
  <img src="assets/webp/dsa.webp" alt="Cozy Groove vinyl shop interior" width="260" height="110">
</picture>
      <p>Vinüülid, kohv ja kogukond.</p>
      <p>Groove | sinu muusika kodu.</p>
    </div>

    <div>
      <h3>POOD</h3>
      <a href="/albums">Albumid</a>
      <a href="/varsti">Uudised</a>
      <a href="/varsti">Kinkekaart</a>
    </div>

    <div>
      <h3>KOHVIK</h3>
      <a href="/varsti">Menüü</a>
      <a href="/varsti">Uudised</a>
      <a href="/varsti">Broneeri laud</a>
    </div>

    <div>
      <h3>INFO</h3>
      <a href="/varsti">Meist</a>
      <a href="/varsti">Üritused</a>
      <a href="/varsti">Privaatsus</a>
    </div>

    <div>
      <h3>KONTAKT</h3>
      <p>info@groove.ee</p>
      <p>+372 1234 4321</p>
      <p>Pärnu mnt. 57, Tallinn</p>
      <div class="socials">@  f</div>
    </div>
  </div>
</footer>

</body>
</html>