<!DOCTYPE html>
<html lang="et">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Groove albumite valik.">
  <title>Groove | Albumid</title>
  <link rel="stylesheet" href="css/style.css">
</head>
<body>

<header class="header">
  <div class="header-container">

    <a href="/" class="logo">
        <picture>
            <source srcset="assets/webp/bgroove.webp" type="image/webp">
            <img src="assets/webp/bgroove.webp" alt="Cozy Groove vinyl shop interior" width="800" height="520">
        </picture>
    </a>

    <nav>
      <ul class="nav-links">
        <li><a href="/">Avaleht</a></li>
        <li><a class="active" href="/albums">Albumid</a></li>
        <li><a href="/varsti">Üritused</a></li>
        <li><a href="/varsti">Meist</a></li>
        <li><a href="/kontakt">Kontakt</a></li>
      </ul>
    </nav>

    <div class="header-icons">
      <a href="#" aria-label="Search">
        <picture>
          <source srcset="assets/webp/search.webp" type="image/webp">
          <img src="assets/webp/search.webp" alt="Search">
        </picture>
      </a>

      <a href="/ostukorv" aria-label="Cart">
        <picture>
  <source srcset="assets/webp/cart.webp" type="image/webp">
  <img src="assets/webp/cart.webp" alt="Cart">
</picture>
      </a>
    </div>

  </div>
</header>

<main>
  <section class="page-hero">
    <div class="container">
      <h1>Albumid</h1>
      <p>Avaleht / Albumid</p>
    </div>
  </section>

  <section class="album-page container">
    <div class="category-row">
      <button class="genre-btn active" data-genre="all">Kõik</button>
<button class="genre-btn" data-genre="rock">Rock</button>
<button class="genre-btn" data-genre="jazz">Jazz</button>
<button class="genre-btn" data-genre="soul">Soul</button>
<button class="genre-btn" data-genre="hiphop">Hip-Hop</button>
<button class="genre-btn" data-genre="electronic">Electronic</button>
    </div>

    <div class="album-layout">
      <aside class="filters">
        <h2>Aasta</h2>

        <label>
  <input type="checkbox" name="year" checked>
  <span>Kõik</span>
</label>

<label>
  <input type="checkbox" name="year">
  <span>2020 - 2026</span>
</label>

<label>
  <input type="checkbox" name="year">
  <span>2010 - 2019</span>
</label>

<label>
  <input type="checkbox" name="year">
  <span>2000 - 2009</span>
</label>

<label>
  <input type="checkbox" name="year">
  <span>1990 - 1999</span>
</label>

<label>
  <input type="checkbox" name="year">
  <span>Enne 1990</span>
</label>

        <h2>Seisukord</h2>

        <label>
  <input type="checkbox" name="condition" checked>
  <span>Hea</span>
</label>

<label>
  <input type="checkbox" name="condition">
  <span>Väga Hea</span>
</label>

<label>
  <input type="checkbox" name="condition">
  <span>Kõik</span>
</label>

<label>
  <input type="checkbox" name="condition">
  <span>Parim</span>
</label>
      </aside>

      <div class="album-content">
        <div class="sort-row">
          <a href="/albums?sort=price">Sorteeri</a>
          <a href="/albums?sort=date">Uusimad</a>
        </div>

        <div class="shop-grid">
  <% albums.forEach(album => { %>

    <article class="shop-card" data-genre="<%= album.genre.toLowerCase() %>">

      <a href="/detail/<%= album.id %>">
        <img
          src="/assets/webp/<%= album.image %>"
          alt="<%= album.artist %> - <%= album.title %>"
          width="800"
          height="250"
          loading="lazy"
        >
      </a>

      <h3><%= album.artist %></h3>
      <p><%= album.title %></p>
      <strong><%= album.price %> €</strong>

    </article>

  <% }) %>
</div>

        <div class="pagination">
          <a class="active" href="/albums">1</a>
          <a href="/albums?page=2">2</a>
          <a href="/albums?page=3">3</a>
          <a href="/albums?page=4">4</a>
          <a href="/albums?page=5">5</a>
        </div>
      </div>
    </div>
  </section>
</main>

<footer class="footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <picture>
  <source srcset="assets/webp/dsa.webp" type="image/webp">
  <img src="assets/webp/dsa.webp" alt="Cozy Groove vinyl shop interior" width="1500" height="110">
</picture>
      <p>Vinüülid, kohv ja kogukond.</p>
      <p>Groove | sinu muusika kodu.</p>
    </div>

    <div>
      <h3>POOD</h3>
      <a href="/albums">Albumid</a>
      <a href="/varsti">Uudised</a>
      <a href="/varsti">Kinkekaart</a>
    </div>

    <div>
      <h3>KOHVIK</h3>
      <a href="/varsti">Menüü</a>
      <a href="/varsti">Uudised</a>
      <a href="/varsti">Broneeri laud</a>
    </div>

    <div>
      <h3>INFO</h3>
      <a href="/varsti">Meist</a>
      <a href="/varsti">Üritused</a>
      <a href="/varsti">Privaatsus</a>
    </div>

    <div>
      <h3>KONTAKT</h3>
      <p>info@groove.ee</p>
      <p>+372 1234 4321</p>
      <p>Pärnu mnt. 57, Tallinn</p>
      <div class="socials">@  f</div>
    </div>
  </div>
</footer>

</body>
</html>