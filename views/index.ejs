<!DOCTYPE html>
<html lang="et">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Groove - vinüülid, kohv ja kogukond.">
  <title>Groove | Avaleht</title>
  
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
  <link rel="stylesheet" href="css/style.css">
</head>
<body

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet" &display=swap>

<header class="header">
  <div class="header-container">

    <a href="/" class="logo">
        <picture>
            <source srcset="assets/webp/bgroove.webp" type="image/webp">
            <img src="assets/webp/bgroove.webp" alt="Cozy Groove vinyl shop interior" width="800" height="520">
        </picture>
    </a>

    <nav>
      <ul class="nav-links">
        <li><a class="active" href="/">Avaleht</a></li>
        <li><a href="/albums">Albumid</a></li>
        <li><a href="/varsti">Üritused</a></li>
        <li><a href="/varsti">Meist</a></li>
        <li><a href="/kontakt">Kontakt</a></li>
      </ul>
    </nav>

    <div class="header-icons">
      <a href="#" aria-label="Search">
        <picture>
          <source srcset="assets/webp/search.webp" type="image/webp">
          <img src="assets/webp/search.webp" alt="Search">
        </picture>
      </a>

      <a href="/ostukorv" aria-label="Cart">
        <picture>
  <source srcset="assets/webp/cart.webp" type="image/webp">
  <img src="assets/webp/cart.webp" alt="Cart">
</picture>
      </a>
    </div>

  </div>
</header>

<main>
  <section class="hero">
    <div class="hero-text">
      <div class="hero-content">
        <h1>VINÜÜLID.<br>KOHVIK.<br>HEA TUJU.</h1>
        <p>Groove on kasutatud plaatide pood ja hubane kohvik. Tule avasta muusikat ja naudi hetke</p>

        <div class="hero-buttons">
          <a href="#" class="btn red">UURI ROHKEM</a>
          <a href="/albums" class="btn outline">VAATA ALBUMEID</a>
        </div>
      </div>
    </div>

    <div class="hero-image">
      <picture>
  <source srcset="assets/webp/gstore.webp" type="image/webp">
  <img src="assets/webp/gstore.webp" alt="Cozy Groove vinyl shop interior" width="800" height="520">
</picture>
    </div>
  </section>

<section class="features container">
  <article>
    <i class="fa-solid fa-record-vinyl"></i>
    <p>Kasutatud vinüülid</p>
  </article>

  <article>
    <i class="fa-solid fa-mug-hot"></i>
    <p>Hubane kohvik</p>
  </article>

  <article>
    <i class="fa-solid fa-calendar-check"></i>
    <p>Kogukond ja üritused</p>
  </article>
</section>

  <section class="albums container">
    <div class="section-head">
      <h2>UUSIMAD ALBUMID</h2>
      <a href="/albums">vaata kõiki <span>→</span></a>
    </div>

    <div class="album-grid">
      <article class="album-card">
        <picture>
            <source srcset="assets/webp/daydreamer.webp" type="image/webp">
        <img src="assets/webp/daydreamer.webp" alt="Cozy Groove vinyl shop interior" loading="lazy">
        </picture>
        <h3>Rulak</h3>
        <p>White Box</p>
        <strong>24.90</strong>
      </article>

      <article class="album-card">
        <picture>
            <source srcset="assets/webp/echo.webp" type="image/webp">
            <img src="assets/webp/echo.webp" alt="Ojlak album cover titled Red Moon" loading="lazy">
        </picture>
        <h3>Ojlak</h3>
        <p>Red Moon</p>
        <strong>22.00</strong>
      </article>

      <article class="album-card">
        <picture>
            <source srcset="assets/webp/moments.webp" type="image/webp">
            <img src="assets/webp/moments.webp" alt="Esuurg album cover titled Tree" loading="lazy">
        </picture>
        <h3>Esuurg</h3>
        <p>Tree</p>
        <strong>26.00</strong>
      </article>

      <article class="album-card">
        <picture>
            <source srcset="assets/webp/simple.webp" type="image/webp">
            <img src="assets/webp/simple.webp" alt="Remmuk album cover titled Mud In The Rain" loading="lazy">
        </picture>
        <h3>Remmuk</h3>
        <p>Mud In The Rain</p>
        <strong>20.00</strong>
      </article>
    </div>
  </section>

<section class="dark-section">
  <div class="container dark-grid">

    <div class="popular-block">
      <h2>POPULAARSED VALIKUD</h2>

      <div class="slider">
        <button class="slider-btn prev" type="button">←</button>

        <div class="slider-window">
          <div class="slider-track">
            <picture>
              <source srcset="assets/webp/echo.webp" type="image/webp">
              <img src="assets/webp/echo.webp" alt="Album">
            </picture>
            <picture>
              <source srcset="assets/webp/daydreamer.webp" type="image/webp">
              <img src="assets/webp/daydreamer.webp" alt="Album">
            </picture>
            <picture>
              <source srcset="assets/webp/simple.webp" type="image/webp">
              <img src="assets/webp/simple.webp" alt="Album">
            </picture>
            <picture>
              <source srcset="assets/webp/daydreamer.webp" type="image/webp">
              <img src="assets/webp/daydreamer.webp" alt="Album">
            </picture>
            <picture>
              <source srcset="assets/webp/moments.webp" type="image/webp">
              <img src="assets/webp/moments.webp" alt="Album">
            </picture>
            <picture>
              <source srcset="assets/webp/echo.webp" type="image/webp">
              <img src="assets/webp/echo.webp" alt="Album">
            </picture>
          </div>
        </div>

        <button class="slider-btn next" type="button">→</button>
      </div>
    </div>

    <aside class="events">
      <h2>TULEVASED ÜRITUSED</h2>

      <div class="event">
        <strong>OO</strong>
        <div>
          <h3>Plaadihommik</h3>
          <p>11. juuni | 11:00 - 13:00</p>
        </div>
      </div>

      <div class="event">
        <strong>OO</strong>
        <div>
          <h3>Live: Silver Ray</h3>
          <p>13. juuni | 18:00</p>
        </div>
      </div>

      <div class="event">
        <strong>OO</strong>
        <div>
          <h3>Kohvik & Vinüüli Õhtu</h3>
          <p>24. juuni | 18:00 - 22:00</p>
        </div>
      </div>

      <a href="#" class="event-btn">VAATA KÕIKI ÜRITUSI</a>
    </aside>

  </div>
</section>
</main>

<footer class="footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <picture>
  <source srcset="assets/webp/dsa.webp" type="image/webp">
  <img src="assets/webp/dsa.webp" alt="Cozy Groove vinyl shop interior" width="260" height="110">
</picture>
      <p>Vinüülid, kohv ja kogukond.</p>
      <p>Groove | sinu muusika kodu.</p>
    </div>

    <div>
      <h3>POOD</h3>
      <a href="/albums">Albumid</a>
      <a href="/varsti">Uudised</a>
      <a href="/varsti">Kinkekaart</a>
    </div>

    <div>
      <h3>KOHVIK</h3>
      <a href="/varsti">Menüü</a>
      <a href="/varsti">Uudised</a>
      <a href="/varsti">Broneeri laud</a>
    </div>

    <div>
      <h3>INFO</h3>
      <a href="/varsti">Meist</a>
      <a href="/varsti">Üritused</a>
      <a href="/varsti">Privaatsus</a>
    </div>

    <div>
      <h3>KONTAKT</h3>
      <p>info@groove.ee</p>
      <p>+372 1234 4321</p>
      <p>Pärnu mnt. 57, Tallinn</p>
      <div class="socials">@  f</div>
    </div>
  </div>
</footer>
<script src="js/main.js"></script>
</body>
</html>
</body>
</html>